# =============================================================
#  AppBit Backend — variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA commite o arquivo .env no controle de versão.
# =============================================================

# ── Banco de dados (MySQL) ────────────────────────────────────
# Endereço do host do MySQL (ex.: localhost ou IP do container)
DB_HOST_APPBIT=localhost

# Porta do MySQL (padrão: 3306)
DB_PORT_APPBIT=3306

# Nome do schema/banco criado para a aplicação
DB_NAME_APPBIT=appbit

# Usuário do banco
DB_USER_APPBIT=appbit_user

# Senha do banco
DB_PASSWORD_APPBIT=sua_senha_aqui

# ── JWT ───────────────────────────────────────────────────────
# Chave secreta usada para assinar os tokens JWT.
# Deve ter pelo menos 32 caracteres (256 bits) para HMAC-SHA256.
# Gere uma chave segura com: openssl rand -base64 48
JWT_SECRET=troque-por-uma-chave-secreta-com-pelo-menos-32-chars

# Tempo de expiração do token em milissegundos.
# 86400000 = 24 horas (padrão usado se esta variável não for definida)
JWT_EXPIRATION_MS=86400000

# ── CORS ─────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula.
# Em produção, substitua pelos domínios reais do frontend.
# Se não definido, assume: http://localhost:5173,http://localhost:4173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
